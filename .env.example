# .env.example
#
# Copy this file to .env and fill in real values.
# .env is in .gitignore and will never be committed to git.
# This file (.env.example) IS committed — it documents what variables are needed.
#
# How to use:
#   cp .env.example .env
#   then edit .env with your real keys

# JagDash login password (bcrypt hash)
# Generate with: python auth.py
# Leave blank to disable authentication (local dev only)
JAGDASH_PASSWORD_HASH=

# Session signing secret — change this to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-long-random-string

# NewsAPI key — get one free at https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# CoinMarketCap API key — get one at https://coinmarketcap.com/api/
# Free tier: current price only. Historical OHLCV requires paid Hobbyist plan.
COINMARKETCAP_KEY=your_coinmarketcap_key_here

# Future keys go here as you add integrations:
# ALPHA_VANTAGE_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
