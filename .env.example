# .env.example
#
# Copy this file to .env and fill in real values.
# .env is in .gitignore and will never be committed to git.
# This file (.env.example) IS committed — it documents what variables are needed.
#
# How to use:
#   cp .env.example .env
#   then edit .env with your real keys

# NewsAPI key — get one free at https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# Future keys go here as you add integrations:
# ALPHA_VANTAGE_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

#session secret -- he session secret should come from the environment in production:
SESSION_SECRET=some-long-random-string-change-this
